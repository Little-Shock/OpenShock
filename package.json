{
  "name": "openshock",
  "private": true,
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "dev": "pnpm --dir apps/web dev",
    "dev:web": "pnpm --dir apps/web dev",
    "dev:server": "powershell -NoLogo -NoProfile -Command \"Set-Location 'apps/server'; go run ./cmd/openshock-server\"",
    "dev:daemon": "powershell -NoLogo -NoProfile -Command \"Set-Location 'apps/daemon'; go run ./cmd/openshock-daemon --workspace-root 'E:\\\\00.Lark_Projects\\\\00_OpenShock'\"",
